# Site URL (used for canonical, sitemap, JSON-LD)
SITE_URL=https://olea-restaurant.fr

# Resend (https://resend.com) — laisser vide en local pour mode log-only
RESEND_API_KEY=
RESEND_FROM="Maison Oléa <contact@olea-restaurant.fr>"

# Destinataire des demandes de devis
CONTACT_EMAIL=contact@olea-restaurant.fr

# Niveau de log Pino (trace | debug | info | warn | error)
LOG_LEVEL=info

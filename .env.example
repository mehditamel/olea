# Site URL (used for canonical, sitemap, JSON-LD, cancellation links)
SITE_URL=https://olea-restaurant.fr
APP_BASE_URL=https://olea-restaurant.fr

# Resend (https://resend.com) — laisser vide en local pour mode log-only
RESEND_API_KEY=
